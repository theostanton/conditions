# Google Cloud
GOOGLE_PROJECT_ID=your-project-id

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
ANALYTICS_BOT_TOKEN=your-analytics-bot-token
ADMIN_CHAT_ID=your-admin-chat-id

# Database (PostgreSQL / Cloud SQL)
PGHOST=localhost
PGDATABASE=conditions
PGUSER=postgres
PGPASSWORD=your-password

# Météo-France API
METEOFRANCE_TOKEN=your-meteofrance-token

# WhatsApp Cloud API
WA_PHONE_NUMBER_ID=your-phone-number-id
WA_ACCESS_TOKEN=your-access-token
WA_VERIFY_TOKEN=your-verify-token

# Google Maps (geocoding)
GOOGLE_MAPS_API_KEY=your-maps-api-key

# Anthropic (conditions reports)
ANTHROPIC_API_KEY=your-anthropic-api-key
